# Google OAuth2 – create a project at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Anthropic – get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# JWT signing secret – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# URLs
# Leave BOTH blank when running behind nginx (Docker / Tailscale tailnet).
# The backend will derive the public URL from the Host + X-Forwarded-Proto
# headers nginx passes, so OAuth redirects automatically use whatever hostname
# the browser used — localhost, a tailnet name, or a custom domain.
#
# Only set these for local dev where frontend and backend run on different ports:
#   FRONTEND_URL=http://localhost:5173
#   BACKEND_URL=http://localhost:8000
FRONTEND_URL=
BACKEND_URL=

# Job search via JSearch on RapidAPI (optional – leave blank to disable job search)
JSEARCH_API_KEY=

# Job recommendation result limit (1–25, default 10)
RECO_LIMIT=10

# LLM provider config (optional – defaults to Anthropic Claude)
# SCORE_PROVIDER=anthropic
# SCORE_MODEL=claude-haiku-4-5-20251001
# CHAT_PROVIDER=anthropic
# CHAT_MODEL=claude-sonnet-4-6
# OPTIMIZE_PROVIDER=anthropic
# OPTIMIZE_MODEL=claude-sonnet-4-6

# Alternative providers (optional)
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# NVIDIA_NIM_API_KEY=
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
