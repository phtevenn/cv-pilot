# Google OAuth2 – create a project at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Anthropic – get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# JWT signing secret – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# URLs (defaults work for local dev)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Job search result limit (1–25, default 10)
RECO_LIMIT=10
